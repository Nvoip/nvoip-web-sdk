{
  "name": "nvoip-web-sdk",
  "version": "0.2.2",
  "description": "SDK Web oficial da Nvoip para embutir OTP e 2FA por SMS, WhatsApp e ligacao usando a API v2.",
  "main": "dist/nvoip-auth-widget.js",
  "browser": "dist/nvoip-auth-widget.js",
  "style": "dist/nvoip-auth-widget.css",
  "files": [
    "dist/nvoip-auth-widget.css",
    "dist/nvoip-auth-widget.js",
    "examples/live-demo.html",
    "examples/mock-demo.html",
    "examples/oauth-token.mjs",
    "examples/server-node.mjs",
    ".env.example",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "demo:mock": "python3 -m http.server 4173 --bind 127.0.0.1",
    "demo:real": "node examples/server-node.mjs",
    "oauth:test": "node examples/oauth-token.mjs",
    "pack:check": "npm pack --dry-run",
    "start": "node examples/server-node.mjs"
  },
  "keywords": [
    "nvoip",
    "web-sdk",
    "otp",
    "authentication",
    "2fa",
    "telefone",
    "sms",
    "whatsapp",
    "voice",
    "api"
  ],
  "author": "Nvoip",
  "license": "GPL-3.0-only",
  "homepage": "https://www.nvoip.com.br/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nvoip/nvoip-web-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/Nvoip/nvoip-web-sdk/issues"
  }
}
